<%layout("layouts/boilerplate")%>

<div class="container-fluid px-2 px-sm-3 px-md-4 mt-3 mt-md-5 mb-5">
  <div class="row mb-4 mb-md-5">
    <div class="col-12">
      <h2 style="color: #222; font-weight: 700; font-size: clamp(24px, 6vw, 32px);">📅 My Bookings</h2>
    </div>
  </div>

  <% if (bookings.length === 0) { %>
    <div class="alert alert-info" role="alert" style="background-color: #e3f2fd; border-left: 4px solid #fe424d; border-radius: 8px; padding: 20px;">
      <h4 class="alert-heading" style="color: #fe424d; font-weight: 700; font-size: 18px;">No Bookings Yet</h4>
      <p style="color: #666; margin-bottom: 15px; font-size: 14px;">You haven't made any bookings yet. Start exploring and book your next adventure!</p>
      <hr>
      <a href="/listings" class="btn" style="background-color: #fe424d; color: white; padding: 10px 20px; border: none; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 14px;">Browse Listings</a>
    </div>
  <% } else { %>
    <div class="row g-3 g-md-4">
      <% bookings.forEach(booking => { %>
        <div class="col-12 col-sm-6 col-lg-6 col-xl-4">
          <div class="card shadow-md" style="border-radius: 12px; border: none; height: 100%;">
            <div class="card-body p-3 p-sm-4">
              <h5 class="card-title" style="color: #222; font-weight: 700; font-size: 16px; margin-bottom: 15px; word-wrap: break-word;"><%= booking.listing.title %></h5>
              
              <div class="booking-info mb-4" style="font-size: 13px;">
                <p style="margin-bottom: 8px;"><strong style="color: #fe424d;">📍 Location:</strong> <span style="word-wrap: break-word;"><%= booking.listing.location %>, <%= booking.listing.country %></span></p>
                <p style="margin-bottom: 8px;"><strong style="color: #fe424d;">📅 Check-In:</strong> <%= booking.checkInDate.toLocaleDateString() %></p>
                <p style="margin-bottom: 8px;"><strong style="color: #fe424d;">📅 Check-Out:</strong> <%= booking.checkOutDate.toLocaleDateString() %></p>
                <p style="margin-bottom: 8px;"><strong style="color: #fe424d;">🌙 Nights:</strong> <%= booking.numberOfNights %></p>
                <p style="margin-bottom: 8px;"><strong style="color: #fe424d;">💰 Total Amount:</strong> ₹<%= booking.totalPrice %></p>
              </div>

              <div class="status-section mb-4">
                <p style="margin-bottom: 10px; font-size: 12px;">
                  <strong style="color: #222;">Booking Status:</strong>
                  <span class="badge" style="background-color: <%= booking.status === 'confirmed' ? '#4caf50' : booking.status === 'cancelled' ? '#fe424d' : '#ff9800' %>; color: white; padding: 5px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;">
                    <%= booking.status.toUpperCase() %>
                  </span>
                </p>
                <p style="margin-bottom: 0; font-size: 12px;">
                  <strong style="color: #222;">Payment Status:</strong>
                  <span class="badge" style="background-color: <%= booking.paymentStatus === 'completed' ? '#4caf50' : booking.paymentStatus === 'refunded' ? '#2196f3' : '#9e9e9e' %>; color: white; padding: 5px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;">
                    <%= booking.paymentStatus.toUpperCase() %>
                  </span>
                </p>
              </div>

              <div class="button-group" style="display: flex; flex-wrap: wrap; gap: 6px; justify-content: flex-start;">
                <a href="/bookings/<%= booking._id %>" class="btn btn-sm" style="background-color: #fe424d; color: white; padding: 6px 12px; border: none; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 11px; cursor: pointer; transition: all 0.3s; flex: 1 1 auto; min-width: 50px; text-align: center;">
                  <i class="fas fa-eye"></i> View
                </a>
                
                <% if (booking.status !== 'cancelled' && booking.paymentStatus !== 'completed') { %>
                  <a href="/bookings/<%= booking._id %>/pay" class="btn btn-sm" style="background-color: #4caf50; color: white; padding: 6px 12px; border: none; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 11px; cursor: pointer; transition: all 0.3s; flex: 1 1 auto; min-width: 50px; text-align: center;">
                    <i class="fas fa-credit-card"></i> Pay
                  </a>
                <% } %>

                <% if (booking.status === 'confirmed' || (booking.status === 'pending' && booking.paymentStatus === 'completed')) { %>
                  <form action="/bookings/<%= booking._id %>/cancel?_method=DELETE" method="POST" style="display: inline; flex: 1 1 auto;" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                    <button type="submit" class="btn btn-sm w-100" style="background-color: #fe424d; color: white; padding: 6px 12px; border: none; border-radius: 6px; font-weight: 700; font-size: 11px; cursor: pointer; transition: all 0.3s;">
                      <i class="fas fa-times-circle"></i> Cancel
                    </button>
                  </form>
                <% } %>

                <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm" style="background-color: #2196f3; color: white; padding: 6px 12px; border: none; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 11px; cursor: pointer; transition: all 0.3s; flex: 1 1 auto; min-width: 50px; text-align: center;">
                  <i class="fas fa-link"></i> Listing
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <div class="mt-4 mt-md-5 mb-5">
    <a href="/listings" class="btn w-100 w-sm-auto" style="background-color: #fe424d; color: white; padding: 12px 30px; border: none; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 14px; display: inline-block;">
      <i class="fas fa-arrow-left"></i> Back to Listings
    </a>
  </div>
</div>

<style>
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(254, 66, 77, 0.2) !important;
  }
  
  .card {
    transition: transform 0.3s, box-shadow 0.3s;
  }
  
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12) !important;
  }

  @media (max-width: 576px) {
    .col-12 {
      width: 100% !important;
    }

    .button-group {
      gap: 4px !important;
    }

    .btn-sm {
      padding: 5px 8px !important;
      font-size: 10px !important;
    }

    .card-body {
      padding: 12px !important;
    }

    h5 {
      font-size: 14px !important;
    }

    p {
      font-size: 12px !important;
      margin-bottom: 6px !important;
    }
  }

  @media (max-width: 768px) {
    .container-fluid {
      padding-left: 8px !important;
      padding-right: 8px !important;
    }
  }
</style>
    </a>
  </div>
</div>
