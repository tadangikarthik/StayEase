<%layout("layouts/boilerplate")%>

<div class="row mt-3 mt-md-5 mb-5">
  <div class="col-12 col-sm-11 col-md-10 col-lg-8 mx-auto">
    <div class="card shadow-lg" style="border-radius: 12px; border: none;">
      <div class="card-header" style="background-color: #fe424d; color: white; border-radius: 12px 12px 0 0; padding: 20px;">
        <h3 class="m-0" style="font-weight: 700; font-size: clamp(20px, 5vw, 28px);">📅 Book Now - <%= listing.title %></h3>
      </div>
      <div class="card-body p-3 p-sm-4 p-md-5">
        <div class="row mb-4 mb-md-5 g-3 g-md-4">
          <div class="col-12 col-md-6">
            <h5 style="color: #222; font-weight: 700; margin-bottom: 15px; font-size: 16px;">Listing Details</h5>
            <p style="margin-bottom: 10px; font-size: 14px;"><strong style="color: #fe424d;">Price per night:</strong> ₹<%= listing.price %></p>
            <p style="margin-bottom: 10px; font-size: 14px;"><strong style="color: #fe424d;">Location:</strong> <%= listing.location %></p>
            <p style="margin-bottom: 10px; font-size: 14px;"><strong style="color: #fe424d;">Country:</strong> <%= listing.country %></p>
          </div>
          <div class="col-12 col-md-6">
            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="img-fluid w-100" style="height: 200px; object-fit: cover; border-radius: 8px;">
          </div>
        </div>

        <hr style="border: 1px solid #e0e0e0; margin: 20px 0;">

        <form action="/bookings/create/<%= listing._id %>" method="POST" id="bookingForm">
          <div class="form-group mb-3 mb-md-4">
            <label for="checkInDate" class="form-label" style="font-weight: 700; color: #222; font-size: 15px; margin-bottom: 10px;"><strong>📍 Check-In Date</strong></label>
            <input type="date" id="checkInDate" name="booking[checkInDate]" class="form-control w-100" required style="padding: 12px 15px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group mb-3 mb-md-4">
            <label for="checkOutDate" class="form-label" style="font-weight: 700; color: #222; font-size: 15px; margin-bottom: 10px;"><strong>📍 Check-Out Date</strong></label>
            <input type="date" id="checkOutDate" name="booking[checkOutDate]" class="form-control w-100" required style="padding: 12px 15px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group mb-4 mb-md-5">
            <label class="form-label" style="font-weight: 700; color: #222; font-size: 15px; margin-bottom: 10px;"><strong>💰 Price Calculation</strong></label>
            <div class="alert alert-info" style="background-color: #e3f2fd; border-left: 4px solid #fe424d; border-radius: 8px; padding: 15px; font-size: 14px;">
              <p style="margin-bottom: 8px;"><strong>Number of Nights:</strong> <span id="nights" style="color: #fe424d; font-size: 16px; font-weight: 700;">0</span></p>
              <p style="margin-bottom: 8px;"><strong>Price per Night:</strong> ₹<%= listing.price %></p>
              <h4 style="color: #fe424d; margin: 0; font-weight: 700; font-size: 18px;"><strong>Total Amount: <span id="totalAmount">₹0</span></strong></h4>
            </div>
          </div>

          <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; flex-direction: column; flex-md-row;" class="flex-column flex-md-row">
            <button type="submit" class="btn btn-custom w-100 w-md-auto" style="background-color: #fe424d; color: white; padding: 12px 25px; font-weight: 700; border: none; border-radius: 8px; font-size: 15px; cursor: pointer; transition: all 0.3s;">
              ✓ Proceed to Payment
            </button>
            <a href="/listings/<%= listing._id %>" class="btn btn-outline-custom w-100 w-md-auto" style="padding: 12px 25px; font-weight: 700; border: 2px solid #fe424d; color: #fe424d; border-radius: 8px; font-size: 15px; text-decoration: none; background-color: white; cursor: pointer; transition: all 0.3s;">
              ✕ Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .btn-custom:hover {
    background-color: #ff2a38 !important;
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(254, 66, 77, 0.3);
  }

  .btn-outline-custom:hover {
    background-color: #fe424d !important;
    color: white !important;
    transform: translateY(-2px);
  }

  #bookingForm input:focus {
    border-color: #fe424d !important;
    box-shadow: 0 0 8px rgba(254, 66, 77, 0.2) !important;
  }

  /* Responsive adjustments */
  @media (max-width: 576px) {
    .card-header {
      padding: 15px !important;
    }
    
    .card-body {
      padding: 12px !important;
    }

    h3 {
      font-size: 20px !important;
    }

    .form-control {
      font-size: 16px !important;
    }
  }

  @media (max-width: 768px) {
    [style*="flex-md-row"] {
      flex-direction: column !important;
    }
  }
</style>

<script>
  const checkInInput = document.getElementById('checkInDate');
  const checkOutInput = document.getElementById('checkOutDate');
  const nightsSpan = document.getElementById('nights');
  const totalAmountSpan = document.getElementById('totalAmount');
  const pricePerNight = <%= listing.price %>;

  // Set minimum check-in date to tomorrow
  function setMinimumDates() {
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    const tomorrowString = tomorrow.toISOString().split('T')[0];
    checkInInput.setAttribute('min', tomorrowString);
  }

  function calculateTotal() {
    if (checkInInput.value && checkOutInput.value) {
      const checkIn = new Date(checkInInput.value);
      const checkOut = new Date(checkOutInput.value);
      const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));

      if (nights > 0) {
        nightsSpan.textContent = nights;
        totalAmountSpan.textContent = '₹' + (pricePerNight * nights);
      } else {
        nightsSpan.textContent = 0;
        totalAmountSpan.textContent = '₹0';
      }
    }
  }

  function updateCheckOutMinimum() {
    if (checkInInput.value) {
      const checkInDate = new Date(checkInInput.value);
      checkInDate.setDate(checkInDate.getDate() + 1);
      const minCheckOutDate = checkInDate.toISOString().split('T')[0];
      checkOutInput.setAttribute('min', minCheckOutDate);
    }
  }

  // Initialize minimum dates on page load
  setMinimumDates();

  // Event listeners
  checkInInput.addEventListener('change', function() {
    updateCheckOutMinimum();
    calculateTotal();
  });
  
  checkOutInput.addEventListener('change', calculateTotal);
</script>
